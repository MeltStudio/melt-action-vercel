{
  "name": "melt-action-vercel",
  "version": "3.1.0",
  "description": "Melt Studio's action to create a Vercel deployment",
  "main": "dist/index.js",
  "repository": "git@github.com:MeltStudio/melt-action-vercel.git",
  "author": "piedrahitapablo <piedra@meltstudio.co>",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "lint": "eslint --max-warnings=0 .",
    "type-check": "tsc --noEmit",
